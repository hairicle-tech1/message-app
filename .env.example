# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=messenger
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=messenger

# ── Redis ──────────────────────────────────────────────────────────────────────
# (no extra config needed — just uses the container)

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-64-char-random-hex-string
JWT_EXPIRES_IN=8h
TOTP_ISSUER=InternalMessenger

# ── Frontend ───────────────────────────────────────────────────────────────────
# Public URL where the backend API is reachable from the browser
VITE_API_URL=http://your-server-ip:4000

# ── MinIO (file storage) ───────────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-minio-password
MINIO_BUCKET=messenger-files

# ── LDAP / SSO (optional — remove if not using LDAP) ──────────────────────────
LDAP_URL=ldap://your-domain-controller:389
LDAP_BASE_DN=dc=company,dc=com
LDAP_BIND_DN=cn=svc-messenger,dc=company,dc=com
LDAP_BIND_PASSWORD=ldap-service-account-password
LDAP_USERNAME_ATTR=uid
# For Active Directory use: sAMAccountName

# ── Firebase Push Notifications (optional) ────────────────────────────────────
# Base64-encode your Firebase service account JSON:
#   base64 -i service-account.json
FIREBASE_SERVICE_ACCOUNT_JSON=
